# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://localhost:3000

# DB
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/carpool_platform"

# Auth
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=CAD

# Email (render|smtp|console)
EMAIL_PROVIDER=console
RENDER_EMAIL_API_KEY=
SMTP_URL=
EMAIL_FROM="no-reply@yourdomain.com"

# Payout/Policies
HOLD_DELAY_DAYS=7
MIN_PAYOUT_AMOUNT=10.00
PAYOUT_FREQUENCY_DAYS=7
