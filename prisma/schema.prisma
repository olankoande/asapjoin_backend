model refund_policies {
  id                              BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  resource_type                   refund_policies_resource_type
  actor_role                      refund_policies_actor_role
  name                            String                        @db.VarChar(120)
  active                          Boolean                       @default(true)
  min_hours_before_departure      Int                           @default(0) @db.UnsignedSmallInt
  refund_request_deadline_hours   Int                           @default(0) @db.UnsignedSmallInt
  cancellation_fee_fixed_cents    Int                           @default(0) @db.UnsignedInt
  cancellation_fee_percent        Decimal                       @default(0) @db.Decimal(5, 2)
  refund_percent_to_customer      Decimal                       @default(100) @db.Decimal(5, 2)
  driver_compensation_percent     Decimal                       @default(0) @db.Decimal(5, 2)
  applies_when_statuses           String                        @db.VarChar(255)
  priority                        Int                           @default(0) @db.SmallInt
  notes                           String?                       @db.Text
  created_at                      DateTime                      @default(now()) @db.DateTime(0)
  updated_at                      DateTime                      @default(now()) @updatedAt @db.DateTime(0)

  @@index([resource_type, actor_role, active], map: "idx_refund_policies_lookup")
}

enum refund_policies_resource_type {
  booking
  delivery
}

enum refund_policies_actor_role {
  passenger
  sender
  driver
  admin
}
